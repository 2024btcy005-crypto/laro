{
  "expo": {
    "name": "Laro Delivery",
    "slug": "laro-delivery",
    "version": "1.0.4",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.zippit.delivery",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}